---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import siteBg from "../../public/site-bg.webp";
import harvenceImg from "../../public/harvence.webp";
import provokeImg from "../../public/provoke.webp";
import curiusImg from "../../public/curius.webp";



const rssResponse = await fetch("https://journal.pybash.xyz/rss.xml");
const rssText = await rssResponse.text();

const articleMatches = [...rssText.matchAll(/<item>([\s\S]*?)<\/item>/g)];
const allArticles = articleMatches.map(match => {
  const content = match[1];
  const title = content?.match(/<title>([\s\S]*?)<\/title>/)?.[1] || "";
  const link = content?.match(/<link>([\s\S]*?)<\/link>/)?.[1]?.replace("/blog/", "/writing/") || "";
  const pubDate = content?.match(/<pubDate>([\s\S]*?)<\/pubDate>/)?.[1] || "";
  
  // Clean up title (unescape common entities)
  const cleanTitle = title.replace(/&apos;/g, "'").replace(/&quot;/g, '"').replace(/&amp;/g, "&");
  
  return {
    title: cleanTitle, 
    link, 
    date: new Date(pubDate),
    displayDate: new Date(pubDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
  };
}).sort((a, b) => b.date.getTime() - a.date.getTime()).slice(0, 3);
---

