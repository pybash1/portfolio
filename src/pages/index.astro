<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Dynamic Header Color
  const header = document.querySelector('#main-header');
  const lightSections = ['#identity-section', '#projects-section', '#project-provoke', '#project-journal', '#writing-section', 'footer'];

  lightSections.forEach((selector) => {
    ScrollTrigger.create({
      trigger: selector,
      start: "top 50px",
      end: "bottom 50px",
      onEnter: () => header?.setAttribute('data-theme', 'light'),
      onLeave: () => header?.setAttribute('data-theme', 'dark'),
      onEnterBack: () => header?.setAttribute('data-theme', 'light'),
      onLeaveBack: () => header?.setAttribute('data-theme', 'dark'),
    });
  });

  // Hide header after hero
  ScrollTrigger.create({
    trigger: "#identity-section",
    start: "top 100px",
    onEnter: () => gsap.to(header, { yPercent: -100, autoAlpha: 0, duration: 0.5, ease: "power2.inOut" }),
    onLeaveBack: () => gsap.to(header, { yPercent: 0, autoAlpha: 1, duration: 0.5, ease: "power2.inOut" }),
  });



  // Writing Section Reveals
  if (document.querySelectorAll("#writing-section a").length > 0) {
    gsap.from("#writing-section a", {
      y: 30,
      duration: 1,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#writing-section",
        start: "top bottom-=50",
        toggleActions: "play none none reverse"
      }
    });
  }

  // Project Section Reveals
  const projectSections = ['#featured-project', '#project-provoke', '#project-journal'];
  projectSections.forEach((selector) => {
    const section = document.querySelector(selector);
    if (!section) return;

    // Reveal images
    const img = section.querySelector('img');
    if (img) {
      gsap.from(img, {
        scale: 1.1,
        opacity: 0.6,
        duration: 1.4,
        ease: "power3.out",
        scrollTrigger: {
          trigger: img,
          start: "top bottom-=100",
          toggleActions: "play none none reverse"
        }
      });
    }

    // Reveal text elements
    const texts = section.querySelectorAll('h2, p, .flex.flex-col.gap-1');
    if (texts.length > 0) {
      gsap.from(texts, {
        y: 40,
        opacity: 0,
        duration: 1,
        stagger: 0.08,
        ease: "power3.out",
        scrollTrigger: {
          trigger: section,
          start: "top bottom-=50",
          toggleActions: "play none none reverse"
        }
      });
    }
  });

  // Marquee — manual rAF loop (GSAP repeat:-1 breaks with negative timeScale)
  const marqueeGroups = document.querySelectorAll('.marquee-group');

  if (marqueeGroups.length > 0) {
    let xPos = 0;
    let speed = -1;       // current speed (px per frame)
    let targetSpeed = -1; // lerp target

    const firstGroup = marqueeGroups[0] as HTMLElement;
    let groupWidth = firstGroup.offsetWidth;

    // Recalculate on resize
    window.addEventListener('resize', () => {
      groupWidth = firstGroup.offsetWidth;
    });

    function tick() {
      // Smooth lerp toward target speed
      speed += (targetSpeed - speed) * 0.05;

      xPos += speed;

      // Seamless wrap in both directions
      if (xPos <= -groupWidth) xPos += groupWidth;
      if (xPos >= 0) xPos -= groupWidth;

      marqueeGroups.forEach((g) => {
        (g as HTMLElement).style.transform = `translateX(${xPos}px)`;
      });

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);

    // Flip direction based on scroll
    ScrollTrigger.create({
      onUpdate: (self) => {
        if (self.direction !== 0) {
          // Scroll down → marquee moves right, scroll up → left
          targetSpeed = self.direction * 1;
        }
      }
    });
  }

  // Refresh ScrollTrigger to account for pinning height changes
  window.addEventListener('load', () => ScrollTrigger.refresh());
</script>

