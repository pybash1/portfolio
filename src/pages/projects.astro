---
import Layout from "../layouts/Layout.astro";
import { projects } from "../lib/utils";

const categoryOrder = ["active", "shipped", "roles", "abandoned"];

const grouped = categoryOrder.reduce<Record<string, typeof projects>>((acc, category) => {
  const items = projects.filter((p) => p.status === category);
  if (items.length > 0) acc[category] = items;
  return acc;
}, {});
---

<Layout title="Projects — Ananjan Mitra">
  <main class="bg-bg text-primary min-h-screen">
    <!-- Header -->
    <header class="fixed top-0 left-0 w-full z-50 p-6 md:p-10 bg-accent">
      <nav class="grid grid-cols-2 font-sans text-bg font-medium text-sm tracking-[0.1em] items-center">
        <div>
          <a href="/" class="opacity-60 hover:opacity-100 transition-opacity duration-300">← Ananjan Mitra</a>
        </div>
        <div class="text-right">&copy; 2026</div>
      </nav>
    </header>

    <div class="bg-accent text-bg pt-40">
      <div class="editorial-container flex flex-col gap-4 border-b border-bg/20 pb-16">
        <h1 class="text-6xl md:text-8xl font-serif tracking-tighter leading-[0.9]">
          <span class="font-fancy text-[1.3em] pr-6">P</span>rojects
        </h1>
        <p class="text-sm font-sans opacity-60 max-w-md mt-4">
          Every project I've built, shipped, paused, abandoned, or merely thought about. Some worked. Most didn't.
        </p>
      </div>
    </div>

    <div class="editorial-container pt-20 pb-32">
      <div class="flex flex-col gap-16">
        {Object.entries(grouped).map(([status, items]) => (
          <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <!-- Status label -->
            <div class="md:col-span-3">
              <span class="text-[10px] uppercase tracking-[0.3em] opacity-40 font-sans sticky top-40">{status}</span>
            </div>
            <!-- Project list -->
            <div class="md:col-span-9 flex flex-col">
              {items.map((project, i) => (
                <div class={`flex items-baseline justify-between py-5 ${i < items.length - 1 ? "border-b border-primary/10" : ""}`}>
                  <div class="flex items-baseline gap-6">
                    <span class="font-sans text-sm font-medium">{project.name}</span>
                    <span class="font-sans text-xs opacity-40 hidden md:block">{project.description}</span>
                  </div>
                  {project.link ? (
                    <a
                      href={project.link}
                      target="_blank"
                      class="group flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] opacity-30 hover:opacity-100 transition-opacity duration-300 font-sans shrink-0 ml-4"
                    >
                      <span>View</span>
                      <svg viewBox="0 0 24 24" class="w-3 h-3 transition-transform duration-300 group-hover:rotate-45" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M7 17L17 7M17 7H7M17 7V17" />
                      </svg>
                    </a>
                  ) : (
                    <span class="text-[10px] uppercase tracking-[0.2em] opacity-20 font-sans shrink-0 ml-4">—</span>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
